{
  "mcp": {
    "servers": {
      "sytra-orchestrator": {
        "command": "node",
        "args": [
          "/absolute/path/to/sytra-mcp/mcp-servers/orchestrator/build/index.js"
        ],
        "env": {
          "WORKFLOWS_DIR": "/absolute/path/to/sytra-mcp/mcp-servers/orchestrator/workflows",
          "SECURITY_API_URL": "http://localhost:8001",
          "CODEGEN_API_URL": "http://localhost:8002",
          "MEMORY_API_URL": "http://localhost:8003",
          "INTELLIGENCE_API_URL": "http://localhost:8004",
          "TOKEN_API_URL": "http://localhost:8005",
          "SDLC_API_URL": "http://localhost:8006",
          "LEGACY_API_URL": "http://localhost:8007",
          "SCHEMA_API_URL": "http://localhost:8008",
          "PERFORMANCE_API_URL": "http://localhost:8009"
        }
      },
      "sytra-intelligence": {
        "command": "node",
        "args": [
          "/absolute/path/to/sytra-mcp/mcp-servers/intelligence-amplification/build/index.js"
        ],
        "env": {
          "INTELLIGENCE_API_URL": "http://localhost:8004"
        }
      },
      "sytra-schema": {
        "command": "node",
        "args": [
          "/absolute/path/to/sytra-mcp/mcp-servers/schema-intelligence/build/index.js"
        ],
        "env": {
          "SCHEMA_API_URL": "http://localhost:8008"
        }
      },
      "sytra-security": {
        "command": "node",
        "args": [
          "/absolute/path/to/sytra-mcp/mcp-servers/security-guardrails/build/index.js"
        ],
        "env": {
          "SECURITY_API_URL": "http://localhost:8001"
        }
      },
      "sytra-codegen": {
        "command": "node",
        "args": [
          "/absolute/path/to/sytra-mcp/mcp-servers/code-generation/build/index.js"
        ],
        "env": {
          "CODEGEN_API_URL": "http://localhost:8002"
        }
      },
      "sytra-memory": {
        "command": "node",
        "args": [
          "/absolute/path/to/sytra-mcp/mcp-servers/memory-management/build/index.js"
        ],
        "env": {
          "MEMORY_API_URL": "http://localhost:8003"
        }
      },
      "sytra-tokens": {
        "command": "node",
        "args": [
          "/absolute/path/to/sytra-mcp/mcp-servers/token-optimization/build/index.js"
