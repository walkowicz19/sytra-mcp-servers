        "env": {
          "TOKEN_API_URL": "http://localhost:8005"
        }
      },
      "sytra-sdlc": {
        "command": "node",
        "args": [
          "/absolute/path/to/sytra-mcp/mcp-servers/sdlc-integration/build/index.js"
        ],
        "env": {
          "SDLC_API_URL": "http://localhost:8006"
        }
      },
      "sytra-legacy": {
        "command": "node",
        "args": [
          "/absolute/path/to/sytra-mcp/mcp-servers/legacy-support/build/index.js"
        ],
        "env": {
          "LEGACY_API_URL": "http://localhost:8007"
        }
      },
      "sytra-performance": {
        "command": "node",
        "args": [
          "/absolute/path/to/sytra-mcp/mcp-servers/performance-optimizer/build/index.js"
        ],
        "env": {
          "PERFORMANCE_API_URL": "http://localhost:8009"
